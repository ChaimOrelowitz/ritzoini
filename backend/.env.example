# Copy this file to .env and fill in your values
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
PORT=4000

# Email (for simulated sending - use a real SMTP later)
NOTIFICATION_EMAIL=notes@ritzoini.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=yourpassword

# Zoom Phone transcript webhook
ZOOM_WEBHOOK_SECRET_TOKEN=your_zoom_event_subscription_secret_token

# Server-to-Server OAuth app (separate from the webhook app above) — used to
# download phone call transcripts, which requires a real bearer token with
# the phone:read:recording_transcript scope
ZOOM_S2S_ACCOUNT_ID=your_zoom_account_id
ZOOM_S2S_CLIENT_ID=your_s2s_app_client_id
ZOOM_S2S_CLIENT_SECRET=your_s2s_app_client_secret
